<link rel="stylesheet" href="{{{uiRootPath}}}/css/site-extra.css">
<meta name="dm-navbar" content="{{or (lookup site.keys 'dark_mode_navbar') 'light'}}">
<script>
(function () {
  const dmNavbar = document.querySelector('meta[name="dm-navbar"]')
  if (dmNavbar && dmNavbar.content) {
    document.documentElement.dataset.dmNavbar = dmNavbar.content
  }
  const MODE = 'antora-theme-mode'
  const LEGACY = 'antora-theme'
  function mode() {
    const m = localStorage.getItem(MODE)
    if (m === 'system' || m === 'dark' || m === 'light') return m
    const o = localStorage.getItem(LEGACY)
    if (o === 'dark' || o === 'light') return o
    return 'system'
  }
  function isDark() {
    const m = mode()
    if (m === 'dark') return true
    if (m === 'light') return false
    return window.matchMedia('(prefers-color-scheme: dark)').matches
  }
  if (isDark()) document.documentElement.classList.add('dark-theme')
})()
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap">
<link rel="stylesheet" href="{{{uiRootPath}}}/css/site-doc-layout.css">
{{#if page.origin.webUrl}}
<meta name="antora-repo-url" content="{{page.origin.webUrl}}">
{{/if}}
