{
  id: "header-chrome",
  name: "Doc site header chrome",
  version: "1.0.0",
  type: "ui-module",
  description: "Sticky site navbar with logo slot, doc title, search slot, VCS link, and doc mast include.",
  repository: "https://github.com/antora-supplemental/valentus-theme",
  requires: ["bc-mast"],
  recommends: ["vcs-icons", "dark-mode"],
  conflicts: [],
  slots: {
    head: {
      links: [
        '<link rel="preconnect" href="https://fonts.googleapis.com">',
        '<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>',
        '<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap">',
      ],
      fragments: ["snippets/repo-meta.hbs"],
    },
  },
  ui: {
    partials: {
      provide: [],
      replace: ["header", "header-content", "head-title"],
    },
  },
}
